{
  "manifest_version": 3,
  "name": "小工具箱",
  "version": "1.0.0",
  "description": "集合实用小工具的Chrome扩展",
  "permissions": [
    "activeTab",
    "cookies",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*.bilibili.com/*",
    "*://*.bigmodel.cn/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/marked.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
